{
  "manifest_version": 3,
  "name": "YouTubeTweaks",
  "version": "1.0",
  "description": "Premium workflow shortcuts for YouTube.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "commands": {
    "toggle-gemini-ask": {
      "suggested_key": {
        "default": "Alt+Comma"
      },
      "description": "Toggle native YouTube Ask/Gemini"
    },
    "toggle-comments": {
      "suggested_key": {
        "default": "Alt+Period"
      },
      "description": "Smart Comments Toggle"
    }
  }
}