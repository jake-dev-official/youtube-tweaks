{
  "manifest_version": 3,
  "name": "YouTubeTweaks",
  "version": "1.0",
  "description": "Premium workflow shortcuts for YouTube.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "commands": {
    "toggle-gemini-ask": {
      "suggested_key": {
        "default": "Alt+Comma"
      },
      "description": "Toggle native YouTube Ask/Gemini"
    },
    "toggle-comments": {
      "suggested_key": {
        "default": "Alt+Period"
      },
      "description": "Smart Comments Toggle"
    },
    "toggle-right-comments": {
      "suggested_key": {
        "default": "Ctrl+Comma"
      },
      "description": "Comments on Right Toggle"
    },
    "toggle-cinematic-mode": {
      "suggested_key": {
        "default": "Ctrl+Period"
      },
      "description": "Cinematic Mode Toggle"
    }
  }
}